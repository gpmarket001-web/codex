  var wheel = document.getElementById('gr-wheel');
  var spinScreen = document.getElementById('gr-spin-screen');
  var resultScreen = document.getElementById('gr-result-screen');
  var lastChanceScreen = document.getElementById('gr-lastchance-screen');
  var resultTitle = document.getElementById('gr-result-title');
  var resultPrize = document.getElementById('gr-result-prize');
  var couponCode = document.getElementById('gr-coupon-code');
  var couponMin = document.getElementById('gr-coupon-min');
  var claimBtn = document.getElementById('gr-claim-btn');
  var lcCode = document.getElementById('gr-lc-code');
  var lcMin = document.getElementById('gr-lc-min');
  var lcClaim = document.getElementById('gr-lc-claim');
  var lcTimer = document.getElementById('gr-lc-timer');
  var timerDisplay = document.getElementById('gr-timer-display');
  var timerWrap = document.getElementById('gr-timer');
  var resultIcon = document.getElementById('gr-result-icon');
  var teaser = document.getElementById('gr-teaser');
  var eyebrow = document.getElementById('gr-eyebrow');
  var subtitle = document.getElementById('gr-subtitle');
  var emailInput = document.getElementById('gr-email');
  var phoneInput = document.getElementById('gr-phone');
  var confettiWrap = document.getElementById('gr-confetti-wrap');
  var hint = document.getElementById('gr-hint');
  var socialText = document.getElementById('gr-social-text');

  var hasOpened = false;
  var hasSpun = false;
  var timerInterval = null;
  var lcInterval = null;
  var triggerSource = 'unknown';
  var currentCoupon = null;
  var soundEnabled = CFG.musicEnabled; // controlado pelo schema (sem toggle no popup — UI limpa)

  // [v11] ===== SCROLL-LOCK iOS + TRAP DE FOCO (acessibilidade premium) =====
  var scrollLockY = 0;
  var lastFocused = null;

  function lockBody() {
    scrollLockY = window.scrollY || window.pageYOffset || 0;
    document.body.style.position = 'fixed';
    document.body.style.top = (-scrollLockY) + 'px';
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.width = '100%';
    document.body.style.overflow = 'hidden';
  }
  function unlockBody() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.width = '';
    document.body.style.overflow = '';
    window.scrollTo(0, scrollLockY);
  }
  function focusableEls() {
    return Array.prototype.slice.call(
      modal.querySelectorAll('button:not([disabled]), input:not([disabled]), a[href], [tabindex]:not([tabindex="-1"])')
    ).filter(function(el) { return el.offsetParent !== null; });
  }
  function focusModal() {
    lastFocused = document.activeElement;
    setTimeout(function() {
      var target = (emailInput && emailInput.offsetParent !== null) ? emailInput : (focusableEls()[0] || closeBtn);
      if (target && target.focus) { try { target.focus({ preventScroll: true }); } catch (e) { try { target.focus(); } catch (e2) {} } }
    }, 80);
  }
  function restoreFocus() {
    if (lastFocused && lastFocused.focus) { try { lastFocused.focus({ preventScroll: true }); } catch (e) {} }
    lastFocused = null;
  }

  // desbloqueia o áudio no primeiríssimo gesto do visitante (regra dos navegadores)
  (function() {
    if (!soundEnabled) return;
    function unlock() {
      var ctx = getAudioContext();
      if (ctx && ctx.state === 'suspended') { try { ctx.resume(); } catch (e) {} }
      ['pointerdown','touchstart','keydown','click'].forEach(function(ev) {
        document.removeEventListener(ev, unlock, true);
      });
    }
    ['pointerdown','touchstart','keydown','click'].forEach(function(ev) {
      document.addEventListener(ev, unlock, true);
    });
  })();
  var audioContext = null;
  var winPlayed = false;
  var audioTimeouts = [];
  var scheduledOscillators = [];

  function scheduleAudio(fn, delay) {
    var id = setTimeout(function() {
      var idx = audioTimeouts.indexOf(id);
      if (idx > -1) audioTimeouts.splice(idx, 1);
      if (overlay.classList.contains('is-open') && soundEnabled) fn();
    }, delay);
    audioTimeouts.push(id);
    return id;
  }
  function cancelAllAudio() {
    audioTimeouts.forEach(function(id) { clearTimeout(id); });
    audioTimeouts = [];
    scheduledOscillators.forEach(function(osc) { try { osc.stop(0); osc.disconnect(); } catch (e) {} });
    scheduledOscillators = [];
    if (audioContext && audioContext.state === 'running') { try { audioContext.suspend(); } catch (e) {} }
  }
  function resumeAudio() {
    if (audioContext && audioContext.state === 'suspended') { try { audioContext.resume(); } catch (e) {} }
  }
  function getAudioContext() {
    if (!soundEnabled) return null;
    if (audioContext) return audioContext;
    try { audioContext = new (window.AudioContext || window.webkitAudioContext)(); } catch (e) {}
    return audioContext;
  }
  function playTickNow() {
    if (!soundEnabled) return;
    var ctx = getAudioContext();
    if (!ctx || ctx.state !== 'running') return;
    try {
      var osc = ctx.createOscillator();
      var gain = ctx.createGain();
      osc.type = 'sine';
      osc.frequency.value = 1100;
      gain.gain.setValueAtTime(0.03, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.022);
      osc.connect(gain); gain.connect(ctx.destination);
      osc.start(); osc.stop(ctx.currentTime + 0.022);
      scheduledOscillators.push(osc);
      setTimeout(function() {
        var idx = scheduledOscillators.indexOf(osc);
        if (idx > -1) scheduledOscillators.splice(idx, 1);
      }, 50);
    } catch (e) {}
  }
  function bezier(t, p1x, p1y, p2x, p2y) {
    var cx = 3 * p1x, bx = 3 * (p2x - p1x) - cx, ax = 1 - cx - bx;
    var cy = 3 * p1y, by = 3 * (p2y - p1y) - cy, ay = 1 - cy - by;
    var x = t;
    for (var i = 0; i < 8; i++) {
      var currentX = ((ax * x + bx) * x + cx) * x - t;
      if (Math.abs(currentX) < 0.001) break;
      var currentSlope = (3 * ax * x + 2 * bx) * x + cx;
      if (Math.abs(currentSlope) < 0.000001) break;
      x = x - currentX / currentSlope;
    }
    return ((ay * x + by) * x + cy) * x;
  }
  function inverseEasing(targetY) {
    var lo = 0, hi = 1, mid;
    for (var i = 0; i < 20; i++) {
      mid = (lo + hi) / 2;
      var y = bezier(mid, 0.17, 0.67, 0.16, 1);
      if (Math.abs(y - targetY) < 0.001) return mid;
      if (y < targetY) lo = mid; else hi = mid;
    }
    return mid;
  }
  function scheduleSyncedTicks(totalRotation, durationMs) {
    if (!soundEnabled) return;
    var ctx = getAudioContext();
    if (!ctx) return;
    if (ctx.state === 'suspended') { try { ctx.resume(); } catch (e) {} }
    var DEGREES_PER_TICK = 30;
    var totalTicks = Math.floor(totalRotation / DEGREES_PER_TICK);
    if (totalTicks > 60) totalTicks = 60;
    for (var i = 1; i <= totalTicks; i++) {
      var targetRotation = i * DEGREES_PER_TICK;
      var progress = targetRotation / totalRotation;
      var time = inverseEasing(progress);
      var delayMs = time * durationMs;
      if (delayMs > durationMs - 80) continue;
      scheduleAudio(playTickNow, delayMs);
    }
  }
  function playNote(ctx, freq, start, dur, type, vol) {
    try {
      var osc = ctx.createOscillator();
      var gain = ctx.createGain();
      osc.type = type || 'triangle';
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0, start);
      gain.gain.linearRampToValueAtTime(vol || 0.12, start + 0.03);
      gain.gain.exponentialRampToValueAtTime(0.001, start + dur);
      osc.connect(gain); gain.connect(ctx.destination);
      osc.start(start); osc.stop(start + dur + 0.05);
      scheduledOscillators.push(osc);
      setTimeout(function() {
        var idx = scheduledOscillators.indexOf(osc);
        if (idx > -1) scheduledOscillators.splice(idx, 1);
      }, (start - ctx.currentTime + dur) * 1000 + 120);
    } catch (e) {}
  }
  // ====== CHIME DE VITÓRIA (premium · suave) — substitui o forró chiptune ======
  function playWin() {
    if (!soundEnabled || winPlayed) return;
    winPlayed = true;
    var ctx = getAudioContext();
    if (!ctx) return;
    if (ctx.state === 'suspended') { try { ctx.resume(); } catch (e) {} }
    var t0 = ctx.currentTime + 0.04;
    // três notas ascendentes com cauda longa (Sol–Si–Ré–Sol↑) — sino quente de sanfona
    var notes = [392.00, 493.88, 587.33, 783.99];
    notes.forEach(function(f, i) {
      playNote(ctx, f, t0 + i * 0.13, 0.95, 'triangle', i === 3 ? 0.13 : 0.10);
    });
    // brilho agudo discreto
    playNote(ctx, 1174.66, t0 + 0.42, 0.6, 'sine', 0.045);
    // base quente curtíssima (corpo de festa, sem peso)
    playNote(ctx, 196.00, t0, 0.7, 'sawtooth', 0.028);
  }
  function hapticFeedback(p) { if ('vibrate' in navigator) try { navigator.vibrate(p); } catch (e) {} }

  function hasActiveCoupon() {
    var exp = ls(KEYS.couponExp);
    return exp && parseInt(exp, 10) > Date.now();
  }
  function canShow() {
    if (hasActiveCoupon()) return false;
    if (ss(KEYS.sessionShown)) return false;
    return true;
  }

  function openRoleta(reason) {
    if (!canShow() || hasOpened) return;
    hasOpened = true;
    triggerSource = reason || 'unknown';
    if (ls(KEYS.closed) && eyebrow && subtitle) {
      eyebrow.textContent = 'Você voltou pra festa';
      subtitle.textContent = 'Vimos que você voltou ao arraiá. Sua chance especial continua de pé.';
    }
    if (emailInput && ls(KEYS.leadEmail)) emailInput.value = ls(KEYS.leadEmail);
    if (phoneInput && ls(KEYS.leadPhone)) phoneInput.value = ls(KEYS.leadPhone);
    overlay.classList.add('is-open');
    lockBody();       // [v11] trava o fundo de verdade (iOS incluso)
    focusModal();     // [v11] move o foco pra dentro do modal
    if (teaser) teaser.classList.remove('is-visible');
    ss(KEYS.sessionShown, '1');
    track('roleta_opened', { trigger: triggerSource });
  }

  function closeRoleta() {
    overlay.classList.remove('is-open');
    unlockBody();     // [v11]
    restoreFocus();   // [v11]
    cancelAllAudio();
    if (!hasSpun) {
      ls(KEYS.closed, '1');
      setTimeout(function() { if (canShow() && teaser) teaser.classList.add('is-visible'); }, 2500);
    }
  }

  function showLastChance() {
    if (ss(KEYS.lastChanceShown)) return;
    if (!ls(KEYS.closed)) return;
    if (hasActiveCoupon()) return;
    if (overlay.classList.contains('is-open')) return;

    ss(KEYS.lastChanceShown, '1');
    var coupon = CFG.coupons.gift;
    var expiresAt = Date.now() + (10 * 60 * 1000);
    ls(KEYS.coupon, coupon.code);
    ls(KEYS.couponExp, String(expiresAt));
    currentCoupon = coupon;

    spinScreen.classList.remove('is-active');
    resultScreen.classList.remove('is-active');
    lastChanceScreen.classList.add('is-active');

    if (lcCode) lcCode.textContent = coupon.code;
    if (lcMin) lcMin.textContent = coupon.min > 0 ? 'Pedido mínimo: R$ ' + coupon.min.toFixed(2).replace('.', ',') : 'Sem valor mínimo';

    function updateLc() {
      var remaining = expiresAt - Date.now();
      if (remaining <= 0) { if (lcTimer) lcTimer.textContent = 'EXPIRADO'; clearInterval(lcInterval); return; }
      var mins = Math.floor(remaining / 60000);
      var secs = Math.floor((remaining % 60000) / 1000);
      if (lcTimer) lcTimer.textContent = (mins < 10 ? '0' : '') + mins + ':' + (secs < 10 ? '0' : '') + secs;
    }
    updateLc();
    lcInterval = setInterval(updateLc, 1000);

    overlay.classList.add('is-open');
    lockBody();       // [v11]
    focusModal();     // [v11]
    hasOpened = true;
    hasSpun = true;

    fireSophisticatedConfetti();
    hapticFeedback([100, 50, 200]);
    playWin();
    track('roleta_won', { prize: 'gift', via: 'last_chance', trigger: triggerSource });
  }

  if (CFG.isHome) setTimeout(function() { openRoleta('home_delay'); }, CFG.homeDelay);
  if (CFG.isProduct) {
    var lastTouch = Date.now();
    ['click', 'touchstart', 'scroll', 'keydown'].forEach(function(ev) {
      document.addEventListener(ev, function() { lastTouch = Date.now(); }, { passive: true });
    });
    setTimeout(function() {
      if (Date.now() - lastTouch >= CFG.productDelay - 2000) openRoleta('product_idle');
    }, CFG.productDelay);
    setTimeout(function() { openRoleta('product_fallback'); }, CFG.productDelay * 2);
  }

  var exitFired = false;
  document.addEventListener('mouseout', function(e) {
    if (exitFired) return;
    if (e.clientY <= 0 && !e.relatedTarget && !e.toElement) {
      exitFired = true;
      if (!hasOpened) openRoleta('exit_desktop');
      else if (!hasSpun) showLastChance();
    }
  });

  var lastScrollY = window.scrollY || 0;
  var lastScrollTime = Date.now();
  var scrollVelocityTriggered = false;
  document.addEventListener('scroll', function() {
    if (scrollVelocityTriggered) return;
    var now = Date.now();
    var dy = (window.scrollY || 0) - lastScrollY;
    var dt = now - lastScrollTime;
    if (dt > 0) {
      var velocity = Math.abs(dy) / dt;
      if (dy < -50 && velocity > 1.5 && window.scrollY < 200) {
        scrollVelocityTriggered = true;
        if (!hasOpened) openRoleta('exit_mobile_scroll');
        else if (!hasSpun && ls(KEYS.closed)) showLastChance();
      }
    }
    lastScrollY = window.scrollY || 0;
    lastScrollTime = now;
  }, { passive: true });

  document.addEventListener('visibilitychange', function() {
    if (document.visibilityState === 'hidden') {
      ls('gr_hidden_at', String(Date.now()));
      cancelAllAudio();
    } else if (document.visibilityState === 'visible') {
      var hiddenAt = parseInt(ls('gr_hidden_at') || '0', 10);
      var awayTime = Date.now() - hiddenAt;
      if (awayTime > 5000 && ls(KEYS.closed) && !hasActiveCoupon() && !ss(KEYS.lastChanceShown)) {
        setTimeout(showLastChance, 600);
      } else if (!hasOpened && ls(KEYS.closed)) {
        setTimeout(function() { openRoleta('return_tab'); }, 800);
      }
    }
  });
  window.addEventListener('beforeunload', function() {
    cancelAllAudio();
    if (!hasSpun && hasOpened) ls(KEYS.closed, '1');
  });
  window.addEventListener('pagehide', cancelAllAudio);

  if (!CFG.isHome && !CFG.isProduct) setTimeout(function() { openRoleta('time_fallback'); }, 30000);

  function getPrizes() {
    var isFirstTime = !ls(KEYS.firstSpin);
    if (isFirstTime) {
      return [
        { key: 'd10',  segment: 0, weight: 80 },
        { key: 'd5',   segment: 1, weight: 6  },
        { key: 'd15',  segment: 2, weight: 5  },
        { key: 'gift', segment: 3, weight: 4  },
        { key: 'd20',  segment: 4, weight: 5  }
      ];
    }
    return [
      { key: 'd10',  segment: 0, weight: 70 },
      { key: 'd5',   segment: 1, weight: 8  },
      { key: 'd15',  segment: 2, weight: 8  },
      { key: 'gift', segment: 3, weight: 6  },
      { key: 'd20',  segment: 4, weight: 8  }
    ];
  }
  function pickPrize() {
    var prizes = getPrizes();
    var total = prizes.reduce(function(s, p) { return s + p.weight; }, 0);
    var r = Math.random() * total;
    var acc = 0;
    for (var i = 0; i < prizes.length; i++) {
      acc += prizes[i].weight;
      if (r <= acc) return prizes[i];
    }
    return prizes[0];
  }
  function validEmail(e) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }
  function validPhone(p) { var d = p.replace(/\D/g, ''); return d.length >= 10 && d.length <= 13; }

  function captureAndSpin() {
    if (CFG.captureLead) {
      var email = emailInput ? emailInput.value.trim() : '';
      if (!validEmail(email)) {
        if (emailInput) { emailInput.classList.add('error'); emailInput.focus(); }
        hapticFeedback(50);
        return;
      }
      ls(KEYS.leadEmail, email);
      var phone = phoneInput ? phoneInput.value.trim() : '';
      if (phone && validPhone(phone)) ls(KEYS.leadPhone, phone);
      track('Lead', { email: email, phone: phone, trigger: triggerSource });
      track('roleta_lead_captured', { trigger: triggerSource });
      sendLeadWebhook(email, phone);
    }
    spin();
  }

  function sendLeadWebhook(email, phone) {
    var url = {{ section.settings.lead_webhook | default: '' | json }};
    if (!url) return;
    try {
      fetch(url, {
        method: 'POST', mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: email, phone: phone, source: 'roleta',
          trigger: triggerSource, page: window.location.href,
          ts: new Date().toISOString()
        })
      });
    } catch (e) {}
  }

  function spin() {
    if (hasSpun) return;
    hasSpun = true;
    winPlayed = false;
    spinBtn.disabled = true;
    spinBtn.classList.add('is-spinning');
    spinBtn.textContent = 'GIRANDO';
    if (hint) hint.style.opacity = '0';
    cancelAllAudio();
    resumeAudio();
    hapticFeedback(30);

    var prize = pickPrize();
    var segSize = 72;
    var segCenter = prize.segment * segSize;
    // margem apertada (0.34) → ponteiro nunca cruza a borda visual do segmento
    var noise = (Math.random() - 0.5) * (segSize * 0.34);
    var fullSpins = 6;
    var totalRotation = (fullSpins * 360) - segCenter + noise;

    wheel.style.transform = 'rotate(' + totalRotation + 'deg)';
    scheduleSyncedTicks(Math.abs(totalRotation), SPIN_MS); // [v11] usa SPIN_MS

    track('roleta_spun', { prize: prize.key, trigger: triggerSource });
    ls(KEYS.firstSpin, '1');

    setTimeout(function() {                                 // [v11] resultado quando a roda PARA
      if (!overlay.classList.contains('is-open')) return;
      showResult(prize);
    }, SPIN_MS + 100);
  }

  function showResult(prize) {
    var coupon = CFG.coupons[prize.key];
    var expiresAt = Date.now() + (CFG.couponMinutes * 60 * 1000);

    ls(KEYS.coupon, coupon.code);
    ls(KEYS.couponExp, String(expiresAt));
    currentCoupon = coupon;

    spinScreen.classList.remove('is-active');
    resultScreen.classList.add('is-active');

    if (prize.key === 'gift') {
      resultScreen.classList.add('gr-gift');
      resultTitle.textContent = 'Brinde do Arraiá';
      resultPrize.textContent = CFG.giftText;
      resultIcon.innerHTML = SVG_GIFT;
    } else {
      resultScreen.classList.remove('gr-gift');
      var pct = prize.key.replace('d', '');
      resultTitle.textContent = pct + '% OFF';
      resultPrize.textContent = 'Você caiu na quadrilha das ofertas!';
      resultIcon.innerHTML = SVG_SPARK;
    }

    couponCode.textContent = coupon.code;
    if (couponMin) couponMin.textContent = coupon.min > 0 ? 'Pedido mínimo: R$ ' + coupon.min.toFixed(2).replace('.', ',') : 'Sem valor mínimo · use no checkout';

    if (socialText) {
      var n = Math.floor(Math.random() * (CFG.socialProofMax - CFG.socialProofMin + 1)) + CFG.socialProofMin;
      socialText.textContent = n + ' pessoas resgataram no arraiá hoje';
    }

    // [v11] após trocar de tela, leva o foco pro botão de resgate (continuidade de teclado)
    if (claimBtn) setTimeout(function() { try { claimBtn.focus({ preventScroll: true }); } catch (e) {} }, 120);

    function updateTimer() {
      var remaining = expiresAt - Date.now();
      if (remaining <= 0) {
        timerDisplay.textContent = 'EXPIRADO';
        timerWrap.classList.add('expired');
        clearInterval(timerInterval);
        return;
      }
      var mins = Math.floor(remaining / 60000);
      var secs = Math.floor((remaining % 60000) / 1000);
      timerDisplay.textContent = (mins < 10 ? '0' : '') + mins + ':' + (secs < 10 ? '0' : '') + secs;
    }
    updateTimer();
    timerInterval = setInterval(updateTimer, 1000);

    fireSophisticatedConfetti();
    hapticFeedback([100, 50, 200, 50, 300]);
    playWin();
    track('roleta_won', { prize: prize.key, coupon_code: coupon.code, trigger: triggerSource });
  }

  // ====== CONFETE EDITORIAL (bandeirinhas + pontos na paleta · sem emoji) ======
  var CONFETTI_COLORS = ['#b3522d', '#bfa05f', '#8a9663', '#854a63', '#e3cf9f', '#efe2c8'];

  function makeShape(color, size) {
    var div = document.createElement('div');
    div.className = 'gr-confetti-shape';
    div.style.setProperty('--c', color);
    if (Math.random() > 0.45) {
      div.classList.add('gr-cf-flag');
      var s = size / 12;
      div.style.transform = 'scale(' + s.toFixed(2) + ')';
    } else {
      div.classList.add('gr-cf-dot');
      div.style.width = (size * 0.6) + 'px';
      div.style.height = (size * 0.6) + 'px';
    }
    return div;
  }

  function fireSophisticatedConfetti() {
    if (!confettiWrap || prefersReducedMotion) return;
    for (var i = 0; i < 28; i++) {
      var color = CONFETTI_COLORS[Math.floor(Math.random() * CONFETTI_COLORS.length)];
      var size = 12 + Math.random() * 12;
      var el = makeShape(color, size);
      el.classList.add('burst');
      var angle = (Math.PI * 2 * i) / 28 + (Math.random() - 0.5) * 0.4;
      var distance = 150 + Math.random() * 220;
      el.style.setProperty('--bx', Math.cos(angle) * distance + 'px');
      el.style.setProperty('--by', Math.sin(angle) * distance - 80 + 'px');
      el.style.setProperty('--br', (Math.random() * 1080 - 540) + 'deg');
      el.style.animationDelay = (Math.random() * 0.2) + 's';
      confettiWrap.appendChild(el);
      (function(e) { setTimeout(function() { e.remove(); }, 2200); })(el);
    }
    setTimeout(function() {
      for (var j = 0; j < 54; j++) {
        var color2 = CONFETTI_COLORS[Math.floor(Math.random() * CONFETTI_COLORS.length)];
        var size2 = 10 + Math.random() * 12;
        var el2 = makeShape(color2, size2);
        el2.classList.add('fall');
        if (Math.random() > 0.5) el2.classList.add('sway');
        el2.style.left = (Math.random() * 100) + '%';
        el2.style.setProperty('--dx', ((Math.random() - 0.5) * 300) + 'px');
        el2.style.setProperty('--rot', (Math.random() * 1080) + 'deg');
        el2.style.setProperty('--dur', (3.6 + Math.random() * 2.4) + 's');
        el2.style.animationDelay = (Math.random() * 1.4) + 's';
        confettiWrap.appendChild(el2);
        (function(e) { setTimeout(function() { e.remove(); }, 7500); })(el2);
      }
    }, 200);
  }

  // ====== CLAIM — REDIRECIONA COM UTMs PRA UTMIFY (igual v8/v9/v10) ======
  function claimCoupon() {
    if (!currentCoupon) return;
    var code = currentCoupon.code;
    var btn = this;

    var doNext = function() {
      track('roleta_coupon_copied', { code: code, trigger: triggerSource });
      hapticFeedback(80);
      cancelAllAudio();

      var utmString = buildUtmString(code, triggerSource);

      if (CFG.isProduct) {
        try {
          var currentUrl = new URL(window.location.href);
          var utms = buildUtmifyParams(code, triggerSource);
          Object.keys(utms).forEach(function(k) { currentUrl.searchParams.set(k, utms[k]); });
          history.replaceState(null, '', currentUrl.toString());
        } catch (e) {}

        btn.textContent = 'Copiado! Use no checkout';
        btn.disabled = true;
        setTimeout(function() {
          overlay.classList.remove('is-open');
          unlockBody();    // [v11]
          restoreFocus();  // [v11]
        }, 1100);
      } else {
        btn.textContent = 'Copiado! Indo pra festa...';
        btn.disabled = true;
        var sep = CFG.redirectUrl.indexOf('?') > -1 ? '&' : '?';
        var finalRedirect = CFG.redirectUrl + sep + utmString;
        var url = '/discount/' + encodeURIComponent(code) + '?redirect=' + encodeURIComponent(finalRedirect);
        setTimeout(function() {
          overlay.classList.remove('is-open');
          unlockBody();    // [v11]
          setTimeout(function() { window.location.href = url; }, 300);
        }, 700);
      }
    };

    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(code).then(doNext).catch(function() { fallbackCopy(code); doNext(); });
    } else { fallbackCopy(code); doNext(); }
  }

  function fallbackCopy(text) {
    var ta = document.createElement('textarea');
    ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
    document.body.appendChild(ta); ta.select();
    try { document.execCommand('copy'); } catch (e) {}
    document.body.removeChild(ta);
  }

  if (spinBtn) spinBtn.addEventListener('click', captureAndSpin);
  if (emailInput) emailInput.addEventListener('input', function() { this.classList.remove('error'); });
  if (closeBtn) closeBtn.addEventListener('click', closeRoleta);
  if (overlay) overlay.addEventListener('click', function(e) { if (e.target === overlay) closeRoleta(); });
  document.addEventListener('keydown', function(e) {
    if (!overlay.classList.contains('is-open')) return;
    if (e.key === 'Escape') { closeRoleta(); return; }
    // [v11] trap de Tab: o foco circula só dentro do modal
    if (e.key === 'Tab') {
      var els = focusableEls();
      if (!els.length) return;
      var first = els[0], last = els[els.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });
  if (claimBtn) claimBtn.addEventListener('click', claimCoupon);
  if (lcClaim) lcClaim.addEventListener('click', claimCoupon);
  if (teaser) teaser.addEventListener('click', function() {
    teaser.classList.remove('is-visible');
    hasOpened = false;
    ss(KEYS.sessionShown, null);
    openRoleta('teaser_click');
  });

})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Roleta Arraiá v11",
  "tag": "section",
  "class": "section-roleta-arraia",
  "settings": [
    { "type": "header", "content": "Ativação" },
    { "type": "checkbox", "id": "enabled", "label": "Ativar Roleta", "default": true },
    { "type": "checkbox", "id": "music_enabled", "label": "Som / chime de vitória", "default": true, "info": "Tick suave no giro + chime na vitória. Desligue se preferir 100% silencioso." },

    { "type": "header", "content": "Captura de Lead" },
    { "type": "checkbox", "id": "capture_lead", "label": "Exigir e-mail antes do giro", "default": true },
    { "type": "checkbox", "id": "capture_whatsapp", "label": "Capturar também WhatsApp", "default": true },
    { "type": "url", "id": "lead_webhook", "label": "Webhook para LEADS (opcional)", "info": "URL pra enviar leads ao CRM/WhatsApp (Zapier/Make). Vendas vão direto pra Utmify via UTMs." },

    { "type": "header", "content": "Textos (Arraiá)" },
    { "type": "text", "id": "eyebrow_text", "label": "Texto superior", "default": "Arraiá da Graça" },
    { "type": "text", "id": "title", "label": "Título", "default": "Gire a roleta do São João" },
    { "type": "textarea", "id": "subtitle", "label": "Subtítulo", "default": "Deixe seu contato e toque na fogueira para girar. A festa tem oferta pra você." },
    { "type": "text", "id": "teaser_text", "label": "Teaser flutuante", "default": "Seu arraiá te espera" },
    { "type": "text", "id": "gift_text", "label": "Mensagem do brinde", "default": "Brinde junino garantido no seu pedido" },

    { "type": "header", "content": "Prova Social" },
    { "type": "number", "id": "social_proof_min", "label": "Mínimo (pessoas)", "default": 8 },
    { "type": "number", "id": "social_proof_max", "label": "Máximo (pessoas)", "default": 24 },

    { "type": "header", "content": "Redirecionamento (Home/Coleção)" },
    { "type": "text", "id": "redirect_url", "label": "URL após copiar", "default": "/collections/all", "info": "Dica de arraiá: aponte para a coleção 'Look de Arraiá' (ex: /collections/look-de-arraia) com o Macacão Alenice em destaque." },

    { "type": "header", "content": "Tempos" },
    { "type": "range", "id": "home_delay", "label": "Home (s)", "min": 1, "max": 30, "step": 1, "default": 3, "unit": "s" },
    { "type": "range", "id": "product_delay", "label": "Produto (s)", "min": 10, "max": 180, "step": 5, "default": 60, "unit": "s" },
    { "type": "range", "id": "coupon_minutes", "label": "Validade (min)", "min": 5, "max": 60, "step": 1, "default": 15, "unit": "min" },

    { "type": "header", "content": "Códigos do Checkout Zedy" },
    { "type": "text", "id": "code_5",    "label": "Código 5% OFF",  "default": "FOGUEIRA5" },
    { "type": "text", "id": "code_10",   "label": "Código 10% OFF", "default": "ARRAIA10" },
    { "type": "text", "id": "code_15",   "label": "Código 15% OFF", "default": "SAOJOAO15" },
    { "type": "text", "id": "code_20",   "label": "Código 20% OFF", "default": "QUADRILHA20" },
    { "type": "text", "id": "code_gift", "label": "Código Brinde",  "default": "BRINDEJUNINO" },

    { "type": "header", "content": "Mínimos (R$) — deixe 0 para sem mínimo" },
    { "type": "number", "id": "min_5",    "label": "Mínimo 5%",  "default": 0 },
    { "type": "number", "id": "min_10",   "label": "Mínimo 10%", "default": 0 },
    { "type": "number", "id": "min_15",   "label": "Mínimo 15%", "default": 0 },
    { "type": "number", "id": "min_20",   "label": "Mínimo 20%", "default": 0 },
    { "type": "number", "id": "min_gift", "label": "Mínimo Brinde", "default": 0 }
  ],
  "presets": [ { "name": "Roleta Arraiá v11" } ]
}
