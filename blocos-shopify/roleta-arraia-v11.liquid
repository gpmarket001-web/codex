      d10:  { code: {{ section.settings.code_10   | default: 'ARRAIA10'     | json }}, min: {{ section.settings.min_10   | default: 0 }} },
      d15:  { code: {{ section.settings.code_15   | default: 'SAOJOAO15'    | json }}, min: {{ section.settings.min_15   | default: 0 }} },
      d20:  { code: {{ section.settings.code_20   | default: 'QUADRILHA20'  | json }}, min: {{ section.settings.min_20   | default: 0 }} },
      gift: { code: {{ section.settings.code_gift | default: 'BRINDEJUNINO' | json }}, min: {{ section.settings.min_gift | default: 0 }} }
    },
    giftText: {{ section.settings.gift_text | default: 'Brinde junino garantido no seu pedido' | json }}
  };

  var KEYS = {
    closed: 'gr_closed', coupon: 'gr_coupon', couponExp: 'gr_coupon_exp',
    leadEmail: 'gr_lead_email', leadPhone: 'gr_lead_phone',
    sessionShown: 'gr_session_shown', lastChanceShown: 'gr_lastchance_shown',
    firstSpin: 'gr_first_spin_done', soundEnabled: 'gr_sound_enabled'
  };

  // ÍCONES DE RESULTADO (SVG editorial — substitui emoji)
  var SVG_SPARK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3.5M12 17.5V21M3 12h3.5M17.5 12H21M5.6 5.6l2.5 2.5M15.9 15.9l2.5 2.5M18.4 5.6l-2.5 2.5M8.1 15.9l-2.5 2.5"/><circle cx="12" cy="12" r="2.3"/></svg>';
  var SVG_GIFT = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><rect x="3" y="8.5" width="18" height="12.5" rx="1"/><path d="M3 12.5h18M12 8.5V21"/><path d="M12 8.5S10.2 4 7.8 4.8 9 8.5 12 8.5zM12 8.5s1.8-4.5 4.2-3.7S15 8.5 12 8.5z"/></svg>';

  if (CFG.isCheckout) return;

  var prefersReducedMotion = false;
  try { prefersReducedMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

  // [v11] tempo de giro centralizado — casa com a transição CSS (4.8s normal / 2.4s reduzido)
  var SPIN_MS = prefersReducedMotion ? 2400 : 4800;

  function ls(k, v) {
    try {
      if (v === undefined) return localStorage.getItem(k);
      if (v === null) { localStorage.removeItem(k); return; }
      localStorage.setItem(k, v);
    } catch (e) {}
  }
  function ss(k, v) {
    try {
      if (v === undefined) return sessionStorage.getItem(k);
      if (v === null) { sessionStorage.removeItem(k); return; }
      sessionStorage.setItem(k, v);
    } catch (e) {}
  }

  function getDevice() {
    return /Mobi|Android|iPhone|iPad/.test(navigator.userAgent) ? 'mobile' : 'desktop';
  }

  function buildUtmifyParams(coupon, trigger) {
    return {
      utm_source: 'roleta',
